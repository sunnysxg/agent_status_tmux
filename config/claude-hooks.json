{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "@HOOKS_DIR@/tmux-agent-status.sh '⚡'",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "@HOOKS_DIR@/tmux-agent-status.sh '✅'",
            "timeout": 3
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "@HOOKS_DIR@/tmux-agent-status.sh '⏸'",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
